@model Author

@{
    ViewBag.Title = "Hello";
}
<div class="center">
    <h2>Author Creation Form</h2>
<form asp-controller="Author" asp-action="Create"  method="POST" >
    <label asp-for="author_name"></label><br/>
    <input asp-for="author_name"/><br/>
    <label asp-for="author_email"></label><br />
    <input asp-for="author_email" /><br />
    <label asp-for="author_password"></label><br />
    <input asp-for="author_password"/><br />
    <label asp-for="author_description"></label>
    <input asp-for="author_description" /><br />
    <input type="submit"  value="Sign In"/>
</form>
</div>